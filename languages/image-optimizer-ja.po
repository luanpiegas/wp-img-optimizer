msgstr "画像を最適化: %1$s - %2$s%%縮小 (%3$s節約)"

#: wp_image_optimizer.php:534
msgid "Advanced Image Optimizer"
msgstr "高度な画像最適化"

#: wp_image_optimizer.php:535
msgid "Image Optimizer"
msgstr "画像最適化"

#: wp_image_optimizer.php:590
msgid "Settings saved successfully!"
msgstr "設定が正常に保存されました！"

#: wp_image_optimizer.php:604
msgid "Statistics have been reset!"
