#: wp_image_optimizer.php:92
msgid "Optimization is already in progress!"
msgstr "最適化は既に進行中です！"

#: wp_image_optimizer.php:93
msgid "Optimizing..."
msgstr "最適化中..."

#: wp_image_optimizer.php:94
msgid "Starting..."
msgstr "開始中..."

#: wp_image_optimizer.php:95
msgid "Found %d images to optimize."
msgstr "最適化する画像が%d件見つかりました。"

#: wp_image_optimizer.php:96
msgid "No images found to optimize."
msgstr "最適化する画像が見つかりませんでした。"

#: wp_image_optimizer.php:97
msgid "Error starting optimization. Check the browser console."
msgstr "最適化の開始中にエラーが発生しました。ブラウザのコンソールを確認してください。"

#: wp_image_optimizer.php:98
msgid "Batch optimization completed successfully!"
msgstr "一括最適化が正常に完了しました！"

