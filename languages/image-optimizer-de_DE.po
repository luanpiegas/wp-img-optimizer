msgid "Maximum width in pixels (100-8000)."
msgstr "Maximale Breite in Pixeln (100-8000)."

#: wp_image_optimizer.php:661
msgid "Maximum Height (px)"
msgstr "Maximale Höhe (px)"

#: wp_image_optimizer.php:664
msgid "Maximum height in pixels (100-8000)."
msgstr "Maximale Höhe in Pixeln (100-8000)."

#: wp_image_optimizer.php:669
msgid "Create Backup"
msgstr "Backup erstellen"

#: wp_image_optimizer.php:672
msgid "Create backup of original images"
msgstr "Backup der Originalbilder erstellen"

#: wp_image_optimizer.php:675
msgid "Saves a copy of the original image before optimization."
msgstr "Speichert eine Kopie des Originalbilds vor der Optimierung."

#: wp_image_optimizer.php:680
msgid "Generate WebP"
msgstr "WebP erzeugen"

#: wp_image_optimizer.php:683
msgid "Generate WebP versions of images"
msgstr "WebP-Versionen der Bilder erzeugen"

#: wp_image_optimizer.php:687
msgid "imagewebp() function not available on the server."
msgstr "Funktion imagewebp() auf dem Server nicht verfügbar."

#: wp_image_optimizer.php:689
msgid "Creates optimized WebP versions for modern browsers."
msgstr "Erstellt optimierte WebP-Versionen für moderne Browser."

#: wp_image_optimizer.php:695
msgid "Serve WebP Images"
msgstr "WebP-Bilder ausliefern"

#: wp_image_optimizer.php:698
msgid "Serve WebP images automatically"
msgstr "WebP-Bilder automatisch ausliefern"

#: wp_image_optimizer.php:701
msgid "If enabled, the plugin will modify the page HTML to serve .webp versions of images to compatible browsers. Requires the \"Generate WebP\" option to be active."
msgstr "Wenn aktiviert, modifiziert das Plugin den HTML der Seite, um .webp-Versionen der Bilder an kompatible Browser auszuliefern. Erfordert, dass die Option „WebP erzeugen“ aktiv ist."

#: wp_image_optimizer.php:706
msgid "Asynchronous Processing"
msgstr "Asynchrone Verarbeitung"

#: wp_image_optimizer.php:709
msgid "Process images in the background"
msgstr "Bilder im Hintergrund verarbeiten"

#: wp_image_optimizer.php:712
msgid "Optimizes images using WP Cron to avoid blocking uploads."
msgstr "Optimiert Bilder mit WP-Cron, um Uploads nicht zu blockieren."

#: wp_image_optimizer.php:717
msgid "Optimize Thumbnails"
msgstr "Vorschaubilder optimieren"

#: wp_image_optimizer.php:720
msgid "Optimize thumbnails generated by WordPress"
msgstr "Von WordPress erstellte Vorschaubilder optimieren"

#: wp_image_optimizer.php:723
msgid "Applies optimization to automatically created thumbnails as well."
msgstr "Wendet die Optimierung auch auf automatisch erstellte Vorschaubilder an."

#: wp_image_optimizer.php:728
msgid "Save Settings"
msgstr "Einstellungen speichern"

#: wp_image_optimizer.php:734
msgid "Optimize Existing Images"
msgstr "Vorhandene Bilder optimieren"

#: wp_image_optimizer.php:735
msgid "Click the button below to optimize all images already existing in the media library."
msgstr "Klicken Sie auf die Schaltfläche unten, um alle bereits in der Mediathek vorhandenen Bilder zu optimieren."

