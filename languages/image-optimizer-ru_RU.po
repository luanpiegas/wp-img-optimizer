msgid "Advanced"
msgstr "Дополнительно"

#: wp_image_optimizer.php:623
msgid "Are you sure you want to reset the statistics?"
msgstr "Вы уверены, что хотите сбросить статистику?"

#: wp_image_optimizer.php:624
msgid "Reset Statistics"
msgstr "Сбросить статистику"

#: wp_image_optimizer.php:634
msgid "Quality (%)"
msgstr "Качество (%)"

#: wp_image_optimizer.php:637
msgid "Compression quality (1-100). Lower value = higher compression."
msgstr "Качество сжатия (1-100). Меньшее значение = большее сжатие."

#: wp_image_optimizer.php:642
msgid "Enable Resizing"
msgstr "Включить изменение размера"

#: wp_image_optimizer.php:645
msgid "Resize images automatically"
msgstr "Автоматически изменять размер изображений"

#: wp_image_optimizer.php:648
msgid "If checked, images will be resized according to the maximum dimensions."
msgstr "Если отмечено, изображения будут изменены до максимальных размеров."

#: wp_image_optimizer.php:653
msgid "Maximum Width (px)"
msgstr "Максимальная ширина (px)"

#: wp_image_optimizer.php:656
msgid "Maximum width in pixels (100-8000)."
msgstr "Максимальная ширина в пикселях (100-8000)."

#: wp_image_optimizer.php:661
msgid "Maximum Height (px)"
msgstr "Максимальная высота (px)"

#: wp_image_optimizer.php:664
msgid "Maximum height in pixels (100-8000)."
msgstr "Максимальная высота в пикселях (100-8000)."

#: wp_image_optimizer.php:669
msgid "Create Backup"
msgstr "Создать резервную копию"

#: wp_image_optimizer.php:672
msgid "Create backup of original images"
msgstr "Создать резервную копию оригиналов изображений"

#: wp_image_optimizer.php:675
msgid "Saves a copy of the original image before optimization."
msgstr "Сохраняет копию оригинала изображения перед оптимизацией."

#: wp_image_optimizer.php:680
msgid "Generate WebP"
msgstr "Генерировать WebP"

#: wp_image_optimizer.php:683
msgid "Generate WebP versions of images"
msgstr "Генерировать WebP-версии изображений"

#: wp_image_optimizer.php:687
msgid "imagewebp() function not available on the server."
msgstr "Функция imagewebp() недоступна на сервере."

#: wp_image_optimizer.php:689
msgid "Creates optimized WebP versions for modern browsers."
msgstr "Создаёт оптимизированные WebP-версии для современных браузеров."

#: wp_image_optimizer.php:695
msgid "Serve WebP Images"
msgstr "Отдавать изображения WebP"

#: wp_image_optimizer.php:698
msgid "Serve WebP images automatically"
msgstr "Автоматически отдавать изображения WebP"

#: wp_image_optimizer.php:701
msgid "If enabled, the plugin will modify the page HTML to serve .webp versions of images to compatible browsers. Requires the \"Generate WebP\" option to be active."
msgstr "Если включено, плагин будет изменять HTML страницы для отдачи .webp-версий изображений совместимым браузерам. Требует включённой опции «Генерировать WebP»."

#: wp_image_optimizer.php:706
msgid "Asynchronous Processing"
msgstr "Асинхронная обработка"

#: wp_image_optimizer.php:709
msgid "Process images in the background"
msgstr "Обрабатывать изображения в фоновом режиме"

#: wp_image_optimizer.php:712
msgid "Optimizes images using WP Cron to avoid blocking uploads."
msgstr "Оптимизирует изображения через WP-Cron, не блокируя загрузки."

#: wp_image_optimizer.php:717
msgid "Optimize Thumbnails"
msgstr "Оптимизировать миниатюры"

#: wp_image_optimizer.php:720
msgid "Optimize thumbnails generated by WordPress"
msgstr "Оптимизировать миниатюры, созданные WordPress"

#: wp_image_optimizer.php:723
msgid "Applies optimization to automatically created thumbnails as well."
msgstr "Применяет оптимизацию также к автоматически созданным миниатюрам."

#: wp_image_optimizer.php:728
msgid "Save Settings"
msgstr "Сохранить настройки"

#: wp_image_optimizer.php:734
msgid "Optimize Existing Images"
msgstr "Оптимизировать существующие изображения"

#: wp_image_optimizer.php:735
msgid "Click the button below to optimize all images already existing in the media library."
msgstr "Нажмите кнопку ниже, чтобы оптимизировать все существующие изображения в медиатеке."

#: wp_image_optimizer.php:740
msgid "Optimizing images..."
msgstr "Оптимизация изображений..."

