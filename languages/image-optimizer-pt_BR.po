msgid "Error optimizing:"
msgstr "Erro ao otimizar:"

#: wp_image_optimizer.php:105
msgid "Unknown error."
msgstr "Erro desconhecido."

#: wp_image_optimizer.php:166
msgid "GD extension not found"
msgstr "Extensão GD não encontrada"

#: wp_image_optimizer.php:174
msgid "Insufficient memory: %s"
msgstr "Memória insuficiente: %s"

#: wp_image_optimizer.php:230
msgid "Rate limit reached for user %d"
msgstr "Limite de taxa atingido para o usuário %d"

