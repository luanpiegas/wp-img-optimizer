msgid "Batch optimization completed successfully!"
msgstr "Otimização em lote concluída com sucesso!"

#: wp_image_optimizer.php:99
msgid "Batch optimization completed with errors."
msgstr "Otimização em lote concluída com erros."

#: wp_image_optimizer.php:100
msgid "A communication error occurred with the server. Optimization was interrupted."
msgstr "Ocorreu um erro de comunicação com o servidor. A otimização foi interrompida."

#: wp_image_optimizer.php:101
msgid "🚀 Start Bulk Optimization"
msgstr "🚀 Iniciar Otimização em Lote"

#: wp_image_optimizer.php:102
msgid "Optimized:"
msgstr "Otimizado:"

#: wp_image_optimizer.php:103
msgid "Remaining:"
msgstr "Restantes:"

