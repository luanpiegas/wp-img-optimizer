#: wp_image_optimizer.php:92
msgid "Optimization is already in progress!"
msgstr "A otimização já está em andamento!"

#: wp_image_optimizer.php:93
msgid "Optimizing..."
msgstr "Otimizando..."

#: wp_image_optimizer.php:94
msgid "Starting..."
msgstr "Iniciando..."

#: wp_image_optimizer.php:95
msgid "Found %d images to optimize."
msgstr "Encontradas %d imagens para otimizar."

